{
  "name": "equidna/bee-hive",
  "description": "Reusable multi-tenant foundation for Laravel applications.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0",
    "illuminate/database": "^12.0",
    "illuminate/http": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.11"
  },
  "autoload": {
    "psr-4": {
      "Equidna\\BeeHive\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Equidna\\BeeHive\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs --standard=ruleset.xml src config tests",
    "audit:deps": "composer audit --no-interaction",
    "analyse": "phpstan analyse --memory-limit=512M",
    "qa:fast": [
      "composer validate --no-check-publish",
      "@lint",
      "@test"
    ],
    "qa": [
      "composer validate --no-check-publish",
      "@audit:deps",
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Equidna\\BeeHive\\BeeHiveServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
