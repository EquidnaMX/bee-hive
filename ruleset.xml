<?xml version="1.0"?>
<ruleset name="BeeHiveStandard">
 <description>BeeHive coding standard based on PSR-12 with adjusted line length.</description>

<!-- Include the whole PHPCS standard -->
 <rule ref="PSR12"/>

 <rule ref="Generic.Files.LineLength">
  <properties>
   <property name="lineLimit" value="180"/>
   <property name="absoluteLineLimit" value="0"/>
  </properties>
 </rule>
</ruleset>
